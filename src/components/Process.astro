---
import SectionHead from './SectionHead.astro';
import type { Content } from '../i18n/en';

interface Props {
  content: Content;
}

const { content } = Astro.props;
const { process } = content;
---

<div class="process">
  <section class="process-inner" id="process" aria-labelledby="process-title">
    <SectionHead
      label={process.label}
      heading={process.heading}
      headingId="process-title"
      aside={process.aside}
    />

    <div class="process-steps">
      {
        process.steps.map((step) => (
          <div class="step">
            <p class="num">{step.num}</p>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        ))
      }
    </div>
  </section>
</div>

---
import SectionHead from './SectionHead.astro';
import type { Content } from '../i18n/en';

interface Props {
  content: Content;
}

const { content } = Astro.props;
const { portfolio } = content;

// reel3 autoplays; the rest hold on a poster frame via the #t=0.1 fragment
// until tapped. public/script.js drives playback and the autoplay fallback.
const reels = [
  { src: '/assets/reel1.mp4#t=0.1', autoplay: false, preload: 'metadata' },
  { src: '/assets/reel2.mp4#t=0.1', autoplay: false, preload: 'metadata' },
  { src: '/assets/reel3.mp4', autoplay: true, preload: 'auto' },
  { src: '/assets/reel4.mp4#t=0.1', autoplay: false, preload: 'metadata' },
];
---

<section id="portfolio" aria-labelledby="portfolio-title">
  <SectionHead
    label={portfolio.label}
    heading={portfolio.heading}
    headingId="portfolio-title"
    aside={portfolio.aside}
  />

  <div class="portfolio-grid">
    {
      portfolio.images.map((img) => (
        <figure class={img.cls}>
          <img src={img.src} loading="lazy" decoding="async" alt={img.alt} />
        </figure>
      ))
    }
  </div>

  <div class="reels-row">
    {
      reels.map((reel, i) => (
        <div class="reel" data-autoplay={reel.autoplay ? '' : undefined} onclick="toggleReel(this)">
          <video
            src={reel.src}
            loop
            muted
            playsinline
            autoplay={reel.autoplay ? true : undefined}
            preload={reel.preload}
            aria-label={`${portfolio.reelLabel} ${i + 1}`}
          />
          <div class="play-btn">
            <div>
              <svg viewBox="0 0 24 24" fill="white" aria-hidden="true">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

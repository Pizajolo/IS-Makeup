---
import { businessNode, personNode } from '../data/schema';
import type { Locale } from '../data/site';
import type { Content } from '../i18n/en';

interface Props {
  locale: Locale;
  content: Content;
  pageUrl: string;
  /** Page-specific entities appended after the business and person nodes. */
  nodes?: Record<string, unknown>[];
}

const { locale, content, pageUrl, nodes = [] } = Astro.props;

// Business and person appear on every page. Referencing them by @id from a
// page that never defines them is the kind of thing Google handles badly, and
// they are cheap to repeat.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [businessNode(locale, content, pageUrl), personNode(content), ...nodes],
};
---

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(jsonLd, null, 2)}
/>

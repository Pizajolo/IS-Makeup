---
import { Image } from 'astro:assets';
import { site, localePath, locales, type Locale } from '../data/site';
import { logoImage } from '../assets/images';
import type { Content } from '../i18n/en';

interface Props {
  locale: Locale;
  content: Content;
}

const { locale, content } = Astro.props;
const { nav } = content;

const sections = [
  { href: '#about', label: nav.about },
  { href: '#services', label: nav.services },
  { href: '#portfolio', label: nav.portfolio },
  { href: '#process', label: nav.process },
  { href: '#faq', label: nav.faq },
  { href: '#contact', label: nav.contact },
];
---

<header class="topbar">
  <a class="brand" href="#top" aria-label={nav.brandAria}>
    <div class="logo">
      <!-- Rendered at 38px; densities cover retina without shipping the 746px source. -->
      <Image
        src={logoImage}
        width={38}
        height={38}
        densities={[1, 2, 3]}
        loading="eager"
        alt={nav.logoAlt}
      />
    </div>
    <div class="name">{site.brandName}</div>
  </a>
  <nav class="main-nav" aria-label={nav.mainNavAria}>
    {sections.map((s) => <a href={s.href}>{s.label}</a>)}
  </nav>
  <div class="topbar-actions">
    <nav class="lang" aria-label={nav.langAria}>
      {
        locales.map((l) => (
          <a
            href={localePath[l]}
            lang={l}
            hreflang={l === locale ? undefined : l}
            aria-current={l === locale ? 'page' : undefined}
          >
            {l.toUpperCase()}
          </a>
        ))
      }
    </nav>
    <a class="book-btn coral" href="#contact">{nav.bookCta}</a>
    <button class="nav-toggle" aria-label={nav.menuAria} aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

---
import { Image } from 'astro:assets';
import { site, localePath, journalPath, locales, type Locale } from '../data/site';
import { logoImage } from '../assets/images';
import type { Content } from '../i18n/en';

interface Props {
  locale: Locale;
  content: Content;
  /**
   * Where each language switch should land. Journal posts pass their own
   * translations so the switcher stays on the article; anything omitted falls
   * back to that locale's homepage.
   */
  langHrefs?: Partial<Record<Locale, string>>;
}

const { locale, content, langHrefs } = Astro.props;
const { nav } = content;

// Section links are in-page anchors on the homepage and absolute everywhere
// else, so the same topbar works from a journal post without dead links.
const onHome = Astro.url.pathname === localePath[locale];
const section = (hash: string) => (onHome ? hash : `${localePath[locale]}${hash}`);

const sections = [
  { href: section('#about'), label: nav.about },
  { href: section('#services'), label: nav.services },
  { href: section('#portfolio'), label: nav.portfolio },
  { href: section('#process'), label: nav.process },
  { href: journalPath[locale], label: nav.journal },
  { href: section('#faq'), label: nav.faq },
  { href: section('#contact'), label: nav.contact },
];
---

<header class="topbar">
  <a class="brand" href={onHome ? '#top' : localePath[locale]} aria-label={nav.brandAria}>
    <div class="logo">
      <!-- Rendered at 38px; densities cover retina without shipping the 746px source. -->
      <Image
        src={logoImage}
        width={38}
        height={38}
        densities={[1, 2, 3]}
        loading="eager"
        alt={nav.logoAlt}
      />
    </div>
    <div class="name">{site.brandName}</div>
  </a>
  <nav class="main-nav" aria-label={nav.mainNavAria}>
    {sections.map((s) => <a href={s.href}>{s.label}</a>)}
  </nav>
  <div class="topbar-actions">
    <nav class="lang" aria-label={nav.langAria}>
      {
        locales.map((l) => (
          <a
            href={langHrefs?.[l] ?? localePath[l]}
            lang={l}
            hreflang={l === locale ? undefined : l}
            aria-current={l === locale ? 'page' : undefined}
          >
            {l.toUpperCase()}
          </a>
        ))
      }
    </nav>
    <a class="book-btn coral" href={section('#contact')}>{nav.bookCta}</a>
    <button class="nav-toggle" aria-label={nav.menuAria} aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

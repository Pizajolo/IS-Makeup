---
import Layout from '../layouts/Layout.astro';
import Topbar from './Topbar.astro';
import Hero from './Hero.astro';
import Marquee from './Marquee.astro';
import About from './About.astro';
import Services from './Services.astro';
import Portfolio from './Portfolio.astro';
import Process from './Process.astro';
import Testimonial from './Testimonial.astro';
import LatestPosts from './LatestPosts.astro';
import Faq from './Faq.astro';
import Contact from './Contact.astro';
import Footer from './Footer.astro';
import { absUrl, faqNode } from '../data/schema';
import { localePath, type Locale } from '../data/site';
import type { Content } from '../i18n/en';

interface Props {
  locale: Locale;
  content: Content;
}

const { locale, content } = Astro.props;

// The FAQPage entity is generated from the visible FAQ, so the two cannot drift.
const schemaNodes = [faqNode(content, absUrl(localePath[locale]))];
---

<Layout locale={locale} content={content} schemaNodes={schemaNodes}>
  <a class="skip-link" href="#main">{content.nav.skipLink}</a>

  <Topbar locale={locale} content={content} />

  <main id="main">
    <Hero content={content} />
    <Marquee content={content} />
    <About content={content} />
    <Services content={content} />
    <Portfolio content={content} />
    <Process content={content} />
    <Testimonial content={content} />
    <LatestPosts locale={locale} content={content} />
    <Faq content={content} />
    <Contact content={content} />
  </main>

  <Footer locale={locale} content={content} />
</Layout>

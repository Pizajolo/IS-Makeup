---
import type { GetStaticPaths } from 'astro';
import JournalPost from '../../components/JournalPost.astro';
import { getPosts, getTranslations, postSlug } from '../../data/journal';
import en from '../../i18n/en';

export const getStaticPaths = (async () => {
  const posts = await getPosts('en');
  return Promise.all(
    posts.map(async (post) => ({
      params: { slug: postSlug(post) },
      props: { post, siblings: posts, translations: await getTranslations(post) },
    })),
  );
}) satisfies GetStaticPaths;

const { post, siblings, translations } = Astro.props;
---

<JournalPost
  locale="en"
  content={en}
  post={post}
  siblings={siblings}
  translations={translations}
/>

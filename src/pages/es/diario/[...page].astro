---
import type { GetStaticPaths } from 'astro';
import JournalIndex from '../../../components/JournalIndex.astro';
import { getPosts, POSTS_PER_PAGE } from '../../../data/journal';
import es from '../../../i18n/es';

export const getStaticPaths = (async ({ paginate }) =>
  paginate(await getPosts('es'), { pageSize: POSTS_PER_PAGE })) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<JournalIndex locale="es" content={es} page={page} />

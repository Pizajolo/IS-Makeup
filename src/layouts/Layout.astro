---
import { getImage } from 'astro:assets';
import { site, localePath, locales, ogLocale, fontsHref, type Locale } from '../data/site';
import { heroImage } from '../assets/images';
import type { Content } from '../i18n/en';
import Schema from '../components/Schema.astro';
import '../styles/global.css';

interface Props {
  locale: Locale;
  content: Content;
}

const { locale, content } = Astro.props;

const canonical = new URL(localePath[locale], site.url).href;

// Social crawlers need a real, absolute URL and many don't decode AVIF, so the
// share image is generated as JPEG rather than reusing the page's <Image> output.
const ogAsset = await getImage({
  src: heroImage,
  width: site.ogImageWidth,
  height: site.ogImageHeight,
  format: 'jpeg',
});
const ogImage = new URL(ogAsset.src, site.url).href;

// og:locale:alternate lists the other two locales, never the current one.
const alternateOgLocales = locales.filter((l) => l !== locale);
---

<!doctype html>
<html lang={content.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{content.meta.title}</title>
    <meta name="description" content={content.meta.description} />
    <meta name="author" content={site.author} />
    <link rel="canonical" href={canonical} />

    {
      locales.map((l) => (
        <link rel="alternate" hreflang={l} href={new URL(localePath[l], site.url).href} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={new URL(localePath.en, site.url).href} />

    <meta name="geo.region" content={site.geo.region} />
    <meta name="geo.placename" content={site.geo.placename} />
    <meta name="geo.position" content={`${site.geo.lat};${site.geo.lng}`} />
    <meta name="ICBM" content={`${site.geo.lat}, ${site.geo.lng}`} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.businessName} />
    <meta property="og:title" content={content.meta.ogTitle} />
    <meta property="og:description" content={content.meta.ogDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content={String(site.ogImageWidth)} />
    <meta property="og:image:height" content={String(site.ogImageHeight)} />
    <meta property="og:locale" content={ogLocale[locale]} />
    {
      alternateOgLocales.map((l) => (
        <meta property="og:locale:alternate" content={ogLocale[l]} />
      ))
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={content.meta.twitterTitle} />
    <meta name="twitter:description" content={content.meta.twitterDescription} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content={site.themeColor} />
    <link rel="icon" href={site.logo} />
    <link rel="apple-touch-icon" href={site.logo} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={fontsHref} rel="stylesheet" />
    {/*
      No <link rel="preload"> for the hero. It now ships a responsive srcset, so
      a fixed-width preload would usually mismatch whichever candidate the
      browser picks and download the image twice. The hero <Image> carries
      loading="eager" + fetchpriority="high" instead, which is the correct
      signal for responsive LCP images.
    */}

    <Schema locale={locale} content={content} />
  </head>
  <body>
    <slot />
    <script is:inline src="/script.js" defer></script>
  </body>
</html>
